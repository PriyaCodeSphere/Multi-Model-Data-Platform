# Streamlit Cloud secrets for the Prism Ask tab (LLM orchestrator).
#
# Copy the four keys below into Streamlit Cloud:
#   Manage app -> Settings -> Secrets  (paste as TOML)
#
# For local development the same variables are read from a .env file at the
# project root or its parent. NEVER commit real values -- .env is gitignored.

AZURE_OPENAI_ENDPOINT = "https://YOUR-RESOURCE.openai.azure.com/"
AZURE_OPENAI_API_KEY = "REPLACE_WITH_YOUR_KEY"
AZURE_OPENAI_CHAT_DEPLOYMENT = "gpt-4.1"
AZURE_OPENAI_API_VERSION = "2025-01-01-preview"
